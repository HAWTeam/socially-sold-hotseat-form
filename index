<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Schedule Your Hot Seat | Socially Sold</title>

<!-- Fonts: DM Serif Display (display), Poppins (body/buttons), IBM Plex Mono (eyebrows) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Poppins:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">

<style>
  :root{
    --linen:#FEF9F4;
    --oat:#EFE7DD;
    --sand:#DACEB8;
    --mocha:#B08B6D;
    --cacao:#5E2E19;
    --periwinkle:#9993F0;
    --indigo:#675DE8;
    --lilac:#D1C6F7;
    --lilac-light:#CEC7FF;
    --citron:#D0EE33;
    --error:#C23B3B;
  }

  *{box-sizing:border-box;}

  body{
    margin:0;
    background:var(--linen);
    color:var(--cacao);
    font-family:'Poppins', sans-serif;
    -webkit-font-smoothing:antialiased;
    padding:48px 20px 80px;
  }

  .wrap{
    max-width:560px;
    margin:0 auto;
    position:relative;
  }

  /* decorative sparkles, matte/flat per brand rules */
  .spark{
    position:absolute;
    pointer-events:none;
  }
  .spark svg{display:block;}

  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:var(--mocha);
    margin:0 0 10px;
  }

  h1{
    font-family:'DM Serif Display', serif;
    font-weight:400;
    font-size:clamp(32px, 6vw, 44px);
    line-height:1.1;
    margin:0 0 14px;
    color:var(--cacao);
  }

  .intro{
    font-size:15px;
    line-height:1.6;
    color:var(--mocha);
    margin:0 0 36px;
    max-width:46ch;
  }

  .divider{
    height:3px;
    width:56px;
    background:var(--citron);
    border:none;
    margin:0 0 32px;
  }

  form{
    background:#fff;
    border:1px solid var(--oat);
    border-radius:18px;
    padding:36px 30px;
  }

  .field{
    margin-bottom:22px;
  }

  .field label{
    display:block;
    font-size:13px;
    font-weight:600;
    margin-bottom:7px;
    color:var(--cacao);
  }

  .field .hint{
    font-family:'IBM Plex Mono', monospace;
    font-size:10.5px;
    letter-spacing:0.05em;
    text-transform:uppercase;
    color:var(--mocha);
    margin-top:6px;
    display:block;
  }

  input[type="text"],
  input[type="email"],
  select{
    width:100%;
    font-family:'Poppins', sans-serif;
    font-size:15px;
    color:var(--cacao);
    background:var(--linen);
    border:1.5px solid var(--sand);
    border-radius:10px;
    padding:13px 14px;
    transition:border-color .15s ease, box-shadow .15s ease;
  }

  input[type="text"]::placeholder,
  input[type="email"]::placeholder{
    color:var(--mocha);
    opacity:.7;
  }

  input[type="text"]:focus,
  input[type="email"]:focus,
  select:focus{
    outline:none;
    border-color:var(--periwinkle);
    box-shadow:0 0 0 4px rgba(153,147,240,0.18);
  }

  select{
    appearance:none;
    -webkit-appearance:none;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20'><path fill='%235E2E19' d='M5 7l5 6 5-6z'/></svg>");
    background-repeat:no-repeat;
    background-position:right 14px center;
    background-size:16px;
    padding-right:38px;
  }

  .row2{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:16px;
  }

  @media (max-width:480px){
    .row2{grid-template-columns:1fr;}
    form{padding:28px 20px;}
  }

  .checkbox-card{
    background:var(--oat);
    border:1.5px solid var(--sand);
    border-radius:14px;
    padding:18px 18px 18px 16px;
    display:flex;
    gap:12px;
    align-items:flex-start;
    margin-bottom:8px;
  }

  .checkbox-card input[type="checkbox"]{
    flex:0 0 auto;
    width:20px;
    height:20px;
    margin-top:2px;
    accent-color:var(--indigo);
    cursor:pointer;
  }

  .checkbox-card label{
    font-size:13.5px;
    line-height:1.55;
    color:var(--cacao);
    cursor:pointer;
  }

  .checkbox-card label strong{
    font-weight:600;
  }

  .error-text{
    display:none;
    color:var(--error);
    font-size:13px;
    line-height:1.6;
    font-weight:500;
    background:#FBEAEA;
    border:1px solid #EBC4C4;
    border-radius:10px;
    padding:13px 14px;
    margin:14px 0 0;
  }

  .error-text a{
    color:var(--error);
    text-decoration:underline;
  }

  .error-text.show{display:block;}

  .duplicate-text{
    display:none;
    color:var(--cacao);
    font-size:13px;
    line-height:1.6;
    font-weight:500;
    background:var(--lilac-light);
    border:1px solid var(--periwinkle);
    border-radius:10px;
    padding:13px 14px;
    margin:14px 0 0;
  }

  .duplicate-text.show{display:block;}

  button[type="submit"]{
    width:100%;
    font-family:'Poppins', sans-serif;
    font-weight:600;
    font-size:15.5px;
    color:var(--linen);
    background:var(--cacao);
    border:none;
    border-radius:10px;
    padding:16px 20px;
    margin-top:8px;
    cursor:pointer;
    transition:background .15s ease, transform .1s ease;
  }

  button[type="submit"]:hover{
    background:var(--indigo);
  }

  button[type="submit"]:active{
    transform:scale(0.99);
  }

  button[type="submit"]:disabled{
    opacity:.65;
    cursor:not-allowed;
  }

  button[type="submit"]:focus-visible,
  input:focus-visible,
  select:focus-visible{
    outline:2px solid var(--indigo);
    outline-offset:2px;
  }

  /* success state */
  .success-card{
    display:none;
    background:#fff;
    border:1px solid var(--oat);
    border-radius:18px;
    padding:44px 30px;
    text-align:center;
  }

  .success-card.show{
    display:block;
    animation:fadeUp .4s ease;
  }

  @keyframes fadeUp{
    from{opacity:0; transform:translateY(8px);}
    to{opacity:1; transform:translateY(0);}
  }

  .success-seal{
    width:64px;
    height:64px;
    margin:0 auto 18px;
  }

  .success-card h2{
    font-family:'DM Serif Display', serif;
    font-weight:400;
    font-size:26px;
    margin:0 0 10px;
    color:var(--cacao);
  }

  .success-card p{
    font-size:14.5px;
    line-height:1.6;
    color:var(--mocha);
    margin:0;
  }

  .footer-note{
    text-align:center;
    font-size:12.5px;
    color:var(--mocha);
    margin-top:28px;
    line-height:1.6;
  }

  .footer-note a{
    color:var(--indigo);
    text-decoration:none;
    font-weight:600;
  }

  @media (prefers-reduced-motion: reduce){
    *{transition:none !important; animation:none !important;}
  }
</style>
</head>
<body>

<div class="wrap">

  <!-- decorative sparkles -->
  <div class="spark" style="top:-18px; right:8px;">
    <svg width="22" height="22" viewBox="0 0 24 24"><path d="M12 0 L14.5 9.5 L24 12 L14.5 14.5 L12 24 L9.5 14.5 L0 12 L9.5 9.5 Z" fill="#D0EE33"/></svg>
  </div>
  <div class="spark" style="top:40px; right:-6px;">
    <svg width="12" height="12" viewBox="0 0 24 24"><path d="M12 0 L14.5 9.5 L24 12 L14.5 14.5 L12 24 L9.5 14.5 L0 12 L9.5 9.5 Z" fill="#D1C6F7"/></svg>
  </div>

  <p class="eyebrow">Socially Sold &middot; Hot Seat Scheduling</p>
  <h1>Claim your hot seat.</h1>
  <p class="intro">Pick your week, confirm you've put in the reps, and a coach will review your Instagram account live. Hot seats run Mondays &amp; Wednesdays at 10am CT.</p>
  <hr class="divider">

  <form id="hotseatForm" novalidate>

    <div class="row2">
      <div class="field">
        <label for="firstName">First name</label>
        <input type="text" id="firstName" name="firstName" placeholder="Ashley" required>
      </div>
      <div class="field">
        <label for="lastName">Last name</label>
        <input type="text" id="lastName" name="lastName" placeholder="Walker" required>
      </div>
    </div>

    <div class="field">
      <label for="email">Email (used at signup)</label>
      <input type="email" id="email" name="email" placeholder="you@email.com" required>
    </div>

    <div class="field">
      <label for="instagram">Instagram handle</label>
      <input type="text" id="instagram" name="instagram" placeholder="@yourhandle" required>
    </div>

    <div class="field">
      <label for="hotseatDate">Choose your hot seat date</label>
      <select id="hotseatDate" name="hotseatDate" required>
        <option value="" disabled selected>Select a date&hellip;</option>
        <option value="Week 2 – Mon Jul 6">Week 2 — Monday, July 6</option>
        <option value="Week 2 – Wed Jul 8">Week 2 — Wednesday, July 8</option>
        <option value="Week 4 – Mon Jul 20">Week 4 — Monday, July 20</option>
        <option value="Week 4 – Wed Jul 22">Week 4 — Wednesday, July 22</option>
        <option value="Week 6 – Mon Aug 3">Week 6 — Monday, August 3</option>
        <option value="Week 6 – Wed Aug 5">Week 6 — Wednesday, August 5</option>
        <option value="Week 8 – Mon Aug 17">Week 8 — Monday, August 17</option>
        <option value="Week 8 – Wed Aug 19">Week 8 — Wednesday, August 19</option>
      </select>
      <span class="hint">All hot seats are Mon/Wed at 10am CT</span>
    </div>

    <div class="duplicate-text" id="duplicateText">
      Looks like you already have a hot seat on the books. If you need to reschedule, email <a href="mailto:ashley@socially-sold.com" style="color:var(--cacao);">ashley@socially-sold.com</a>.
    </div>

    <div class="checkbox-card">
      <input type="checkbox" id="prereqCheck" name="prereqCheck">
      <label for="prereqCheck"><strong>I've posted at least 5 posts</strong> (reels/carousels), completed my small branding call, and watched Modules 1 &amp; 2.</label>
    </div>

    <div class="error-text" id="errorText">
      Please post 5 posts, book your branding call, and watch Modules 1 &amp; 2 before scheduling your hot seat. If you have questions, email <a href="mailto:ashley@socially-sold.com">ashley@socially-sold.com</a>
    </div>

    <button type="submit" id="submitBtn">Schedule my hot seat</button>
  </form>

  <div class="success-card" id="successCard">
    <div class="success-seal">
      <svg viewBox="0 0 64 64" width="64" height="64">
        <circle cx="32" cy="32" r="30" fill="#9993F0"/>
        <path d="M32 18 L36 28 L46 32 L36 36 L32 46 L28 36 L18 32 L28 28 Z" fill="#FEF9F4"/>
      </svg>
    </div>
    <h2>Request received!</h2>
    <p>Our team will review your request and add you to the list. Keep in mind: if you've already had your hot seat, you may get skipped or scheduled to the end of the list.</p>
  </div>

  <p class="footer-note">Questions? Email <a href="mailto:ashley@socially-sold.com">ashley@socially-sold.com</a></p>

</div>

<script>
  /* ============================================================
     DUPLICATE-PREVENTION LIST
     Add a student's email here the moment they're confirmed
     Scheduled or Completed in the Hot Seat Tracker, so the form
     blocks them from booking a second session.
     Format: 'email@example.com',
     ============================================================ */
  const ALREADY_SCHEDULED = [
    // 'student@example.com',
  ];

  // Slack Incoming Webhook — posts only to the configured channel.
  const SLACK_WEBHOOK_URL = 'https://hooks.slack.com/services/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';

  const form = document.getElementById('hotseatForm');
  const errorText = document.getElementById('errorText');
  const duplicateText = document.getElementById('duplicateText');
  const submitBtn = document.getElementById('submitBtn');
  const successCard = document.getElementById('successCard');
  const emailInput = document.getElementById('email');

  function checkDuplicate() {
    const email = emailInput.value.trim().toLowerCase();
    const isDup = email.length > 0 && ALREADY_SCHEDULED.includes(email);
    duplicateText.classList.toggle('show', isDup);
    return isDup;
  }

  emailInput.addEventListener('blur', checkDuplicate);

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    errorText.classList.remove('show');

    const checked = document.getElementById('prereqCheck').checked;
    if (!checked) {
      errorText.classList.add('show');
      errorText.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    if (checkDuplicate()) {
      return;
    }

    const firstName = document.getElementById('firstName').value.trim();
    const lastName = document.getElementById('lastName').value.trim();
    const email = emailInput.value.trim();
    const instagram = document.getElementById('instagram').value.trim();
    const dateSelect = document.getElementById('hotseatDate');
    const dateLabel = dateSelect.options[dateSelect.selectedIndex].text;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Scheduling…';

    const slackPayload = {
      text: `*New Hot Seat Scheduled* | ${firstName} ${lastName} - ${dateLabel}`,
      blocks: [
        {
          type: 'header',
          text: { type: 'plain_text', text: `New Hot Seat Scheduled | ${firstName} ${lastName} - ${dateLabel}` }
        },
        {
          type: 'section',
          fields: [
            { type: 'mrkdwn', text: `*Name:*\n${firstName} ${lastName}` },
            { type: 'mrkdwn', text: `*Email:*\n${email}` },
            { type: 'mrkdwn', text: `*Instagram:*\n${instagram}` },
            { type: 'mrkdwn', text: `*Hot Seat Date:*\n${dateLabel}` }
          ]
        },
        {
          type: 'context',
          elements: [{ type: 'mrkdwn', text: 'Add this student to the Hot Seat Tracker roster.' }]
        }
      ]
    };

    try {
      await fetch(SLACK_WEBHOOK_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(slackPayload)
      });
    } catch (err) {
      // no-cors fetch never gives readable errors/success - we proceed regardless
    }

    form.style.display = 'none';
    successCard.classList.add('show');
  });
</script>

</body>
</html>
